# basic config stuff
<IfModule mod_env.c>
    SetEnv TZ America/Los_Angeles
    SetEnv SERVER_ADMIN support@zen-ish.space
</IfModule>

AddDefaultCharset UTF-8
DefaultLanguage en-US

# HSTS and Content-Security-Policy
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; script-src 'self' 'unsafe-inline' 'unsafe-hashes'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; form-action 'self'; frame-src 'none'; worker-src 'self'; manifest-src 'self'; upgrade-insecure-requests"
</IfModule>

# do not let people browse directories, do follow symbolic links
Options -Indexes +FollowSymLinks
IndexIgnore *

# given the root as the url of interest, go to index.html
DirectoryIndex index.html

# ensure rewrite engine is on
RewriteEngine On

# edit as needed when the site must be down
# make the next line whatever one page you want to have up to explain what's going on and when users can come back
#ErrorDocument 403 temporarilyDownForMaintenace.html
# make all access into a 403 (forbidden)
#Order deny,allow
#Deny from all
# make the next line whatever ip address you will come in from
#Allow from 555.555.555.555

# always use https
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# nullify old www convention if it is used
RewriteCond %{HTTP_HOST} ^www\.
RewriteCond %{HTTPS}s ^on(s)|off
RewriteCond http%1://%{HTTP_HOST} ^(https?://)(www\.)?(.+)$
RewriteRule ^ %1%3%{REQUEST_URI} [R=301,L]

# hide .html endings
# redirect /file.html to /file
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html [NC]
RewriteRule ^ /%1 [NE,L,R]
# map /file to /file.html
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)/?$ /$1.html [L]
# map / to /index
RewriteRule ^$ /index [R=301,L]

# redirect outdated urls to new layout
Redirect 301 /articles/agriculture-ruined-everything /articles/agriculture

# avoid nonsensical MIME type problems when loading javascript files
AddType text/javascript .js
AddType text/javascript .mjs

# redirect error messages from the webserver to avoid ugly default error messages
# almost none of these will be relevant for us in real life
# those commented out cause unrecoverable errors if uncommented!
#ErrorDocument 418 /html/418.html
#ErrorDocument 420 /html/420.html
#ErrorDocument 425 /html/425.html
#ErrorDocument 430 /html/430.html
#ErrorDocument 451 /html/451.html
ErrorDocument 400 /html/400.html
ErrorDocument 401 /html/401.html
ErrorDocument 402 /html/402.html
ErrorDocument 403 /html/403.html
ErrorDocument 404 /html/404.html
ErrorDocument 405 /html/405.html
ErrorDocument 406 /html/406.html
ErrorDocument 407 /html/407.html
ErrorDocument 408 /html/408.html
ErrorDocument 409 /html/409.html
ErrorDocument 410 /html/410.html
ErrorDocument 411 /html/411.html
ErrorDocument 412 /html/412.html
ErrorDocument 413 /html/413.html
ErrorDocument 414 /html/414.html
ErrorDocument 415 /html/415.html
ErrorDocument 416 /html/416.html
ErrorDocument 417 /html/417.html
ErrorDocument 421 /html/421.html
ErrorDocument 422 /html/422.html
ErrorDocument 423 /html/423.html
ErrorDocument 424 /html/424.html
ErrorDocument 426 /html/426.html
ErrorDocument 428 /html/428.html
ErrorDocument 429 /html/429.html
ErrorDocument 500 /html/500.html
ErrorDocument 501 /html/501.html
ErrorDocument 502 /html/502.html
ErrorDocument 504 /html/504.html
ErrorDocument 505 /html/505.html
ErrorDocument 506 /html/506.html
ErrorDocument 507 /html/507.html
ErrorDocument 508 /html/508.html
ErrorDocument 510 /html/510.html
ErrorDocument 511 /html/511.html

# forbid access to this and various other files
# no access to dot files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
# no access to files with these extensions
# do NOT block *.txt -- as this screws up annual auto-renew of TLS cert
<FilesMatch "\.(cfg|enc|ini|json|json5|key|log|psd|scss|sql)$">
    Order allow,deny
    Deny from all
</FilesMatch>
# no access to files in these directories
RewriteRule (/backend/|/sec/|/test/|/tmp/) - [F,L,NC]

# ensure AutoSSL has access to the .well-known folders and files it may use
<FilesMatch "\.well-known/(acme-challenge|cpanel-dcv|pki-validation)/.*">
    Allow from all
</FilesMatch>

# set some headers as we like them
Header set X-Frame-Options: deny
Header set Referrer-Policy: no-referrer
Header set X-Content-Type-Options: nosniff
Header set X-DNS-Prefetch-Control: On

# enable cross domain access from us to for 3rd-party fonts, javascript libraries, google analytics, and such
<IfModule mod_headers.c>
    <FilesMatch "\.(php|jpg|gif|png|ico|css|js|mjs|html|json)$">
        SetEnvIf Origin "http(s)?://(www\.)?(google.com|fontawesome.io)$" origin=$0
        Header add Access-Control-Allow-Origin %{origin}e env=origin
        Header merge Vary Origin
    </FilesMatch>
    <FilesMatch "\.(ttf|ttc|otf|eot|woff|woff2|css)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>

#LimitRequestBody 16777216
<IfModule mod_security2.c>
    SecRequestBodyLimit        16777216
    SecRequestBodyNoFilesLimit 16777216
</IfModule>

# performance factors
# default etag for cache control
FileETag MTime Size
<ifmodule mod_expires.c>
  <filesmatch "\.(html|php|webp|jpg|png|gif|ico|css|js)$">
       ExpiresActive on
       ExpiresDefault "access plus 1 year"
   </filesmatch>
</ifmodule>
# very small site, very few visitors, defeat all caching so users always get the latest of everything
<IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
</IfModule>
<IfModule mod_deflate.c>
    # Force compression for mangled headers.
    # https://developer.yahoo.com/blogs/ydn/posts/2010/12/pushing-beyond-gzipping
    <IfModule mod_setenvif.c>
            <IfModule mod_headers.c>
                SetEnvIfNoCase ^(Accept-EncodXng|X-cept-Encoding|X{15}|~{15}|-{15})$ ^((gzip|deflate)\s*,?\s*)+|[X~-]{4,13}$ HAVE_Accept-Encoding
                RequestHeader append Accept-Encoding "gzip,deflate" env=HAVE_Accept-Encoding
            </IfModule>
    </IfModule>
    # Compress all output labeled with one of the following MIME-types
    <IfModule mod_filter.c>
        AddOutputFilterByType DEFLATE application/atom+xml \
            application/javascript \
            application/json \
            application/rss+xml \
            application/vnd.ms-fontobject \
            application/x-font-ttf \
            application/x-web-app-manifest+json \
            application/xhtml+xml \
            application/xml \
            font/opentype \
            image/svg+xml \
            image/x-icon \
            text/css \
            text/html \
            text/plain \
            text/x-component \
            text/xml
    </IfModule>
</IfModule>
<IfModule pagespeed_module>
    ModPagespeed on
    ModPagespeedEnableFilters collapse_whitespace
    ModPagespeedEnableFilters combine_css
    ModPagespeedEnableFilters combine_javascript
    ModPagespeedEnableFilters extend_cache
    ModPagespeedEnableFilters jpeg_subsampling
    ModPagespeedEnableFilters prioritize_critical_css
    ModPagespeedEnableFilters recompress_images
    ModPagespeedEnableFilters remove_comments
    ModPagespeedEnableFilters remove_quotes
    ModPagespeedEnableFilters rewrite_css
    ModPagespeedEnableFilters rewrite_images
    ModPagespeedEnableFilters strip_image_meta_data
</IfModule>
<ifModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/xml text/css text/plain
    AddOutputFilterByType DEFLATE image/svg+xml application/xhtml+xml application/xml
    AddOutputFilterByType DEFLATE application/rdf+xml application/rss+xml application/atom+xml
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript application/json
    AddOutputFilterByType DEFLATE application/x-font-ttf application/x-font-otf
    AddOutputFilterByType DEFLATE font/truetype font/opentype
</ifModule>
<Files *>
    SetOutputFilter DEFLATE
</Files>
# end of performance factors

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php74” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php74 .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit